# Backend environment — copy to backend/.env locally, set as env vars on Railway
SPOTIFY_CLIENT_ID=your_client_id
SPOTIFY_CLIENT_SECRET=your_client_secret
# Local dev uses the loopback callback; in prod use your deployed callback URL
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/auth/callback

# Postgres. Local example shown; Railway injects its own DATABASE_URL
DATABASE_URL=postgresql://sid@localhost/fidolio

LASTFM_API_KEY=your_lastfm_key
GENIUS_ACCESS_TOKEN=your_genius_token

# Comma-separated list of allowed frontend origins for CORS.
# Add your Vercel URL here in production, e.g.:
# CORS_ORIGINS=http://localhost:5173,https://fidolio.vercel.app
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
